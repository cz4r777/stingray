# Stingray uses Supabase ONLY as an opaque ciphertext relay.
# The server CANNOT decrypt anything. See docs/architecture.md and docs/threat_model.md.
EXPO_PUBLIC_RELAY_URL=https://YOUR-PROJECT-REF.supabase.co
EXPO_PUBLIC_RELAY_ANON_KEY=YOUR-ANON-KEY-HERE

# Hard-fail the client if cellular is the only available transport (Faraday mode).
# When true, the app refuses to send/receive any data over a cell radio.
# See docs/invariants.md I1 and docs/security_rules.md §2.
EXPO_PUBLIC_FARADAY_MODE=true
